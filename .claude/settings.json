{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(npm install*)",
      "Bash(rm *)",
      "Bash(del *)",
      "Bash(git push*)"
    ]
  }
}